# ===================================================================
# JMONEY GAMEFI 環境變數設定
# ===================================================================
# 複製此檔案為 .env.local 並填入你的值
# 或直接在 Vercel 專案設定中加入這些變數

# ===================================================================
# Web3 連接設定
# ===================================================================

# Helius RPC - 快速穩定的 Solana 節點
# 免費 API Key: https://app.helius.dev/
# 替換 YOUR_HELIUS_KEY 為你的實際 API Key
VITE_RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ===================================================================
# Helius API Key (用於讀取代幣元資料)
# ===================================================================
# 從 https://app.helius.dev/ 取得
VITE_HELIUS_API_KEY=YOUR_HELIUS_API_KEY
